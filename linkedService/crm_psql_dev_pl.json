{
	"name": "crm_psql_dev_pl",
	"type": "Microsoft.DataFactory/factories/linkedservices",
	"properties": {
		"parameters": {
			"database_name": {
				"type": "string",
				"defaultValue": "iclub"
			}
		},
		"annotations": [],
		"type": "AzurePostgreSql",
		"version": "2.0",
		"typeProperties": {
			"server": "pg-cic-crm-dev-01.privatelink.postgres.database.azure.com",
			"port": "5432",
			"database": "@{linkedService().database_name}",
			"sslMode": 2,
			"authenticationType": "SystemAssignedManagedIdentity"
		},
		"connectVia": {
			"referenceName": "ManagedIntegrationRuntime",
			"type": "IntegrationRuntimeReference"
		}
	}
}